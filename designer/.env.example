# Supabase auth — copy to .env.local and fill in real values.
# When either is missing, the app runs fully offline with auth disabled.
# The anon/publishable key is designed to ship in the browser bundle;
# Row Level Security (RLS) policies protect your data, not key secrecy.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional: store project file blobs in a Supabase Storage bucket instead of the
# Postgres row (keeps large projects out of the DB). Create the bucket + policies
# with supabase/storage.sql, then set the bucket name here. Unset = inline (capped).
VITE_SUPABASE_STORAGE_BUCKET=

# Optional: base URL of the hosted 3D-model library. Production builds default
# to the R2-hosted full KiCad 10 set (see .env.production); set it here (via
# .env.local) to also use the full library in dev. Unset in dev = the small
# bundled demo set under /models3d (this repo's public/models3d).
VITE_MODELS3D_URL=

+// Build a dark schematic theme from a small palette (keeps every Theme key
+// populated by spreading the KiCad default first).
+function darkTheme(p: {
+  bg: string;
+  fill: string;
+  dim: string;
+  fg: string;
+  green: string;
+  blue: string;
+  red: string;
+  cyan: string;
+  yellow: string;
+  purple: string;
+}): Theme {
+  return {
+    ...KICAD_DEFAULT,
+    background: p.bg,
+    grid: p.dim,
+    wire: p.green,
+    bus: p.blue,
+    busJunction: p.blue,
+    junction: p.green,
+    symbolOutline: p.red,
+    symbolFill: p.fill,
+    pin: p.cyan,
+    pinName: p.cyan,
+    pinNumber: p.yellow,
+    reference: p.cyan,
+    value: p.fg,
+    fields: p.purple,
+    label: p.fg,
+    globalLabel: p.red,
+    hierLabel: p.yellow,
+    noteLine: p.blue,
+    noText: p.blue,
+    noConnect: p.purple,
+    sheetBorder: p.red,
+    sheetName: p.cyan,
+    sheetFile: p.yellow,
+    pageFrame: p.red,
+    cursor: p.fg,
+  };
+}

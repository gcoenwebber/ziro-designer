+/* Plugin and Content Manager dialog (DIALOG_PCM). Reuses the shell modal chrome
+   (.ze-modal / .ze-btn) and adds the repository bar, tabs and package cards. */
+
+.ze-modal.ze-pcm-dialog {
+  width: 820px;
+  height: 640px;
+}
+
+.ze-pcm-repobar {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 8px 12px;
+  border-bottom: 1px solid var(--chrome-border);
+  flex-wrap: wrap;
+}
+.ze-pcm-repobar select,
+.ze-pcm-addrepo input {
+  background: var(--chrome-bg2);
+  color: var(--chrome-fg);
+  border: 1px solid var(--chrome-border);
+  border-radius: 4px;
+  padding: 3px 6px;
+  font: inherit;
+}
+.ze-pcm-addrepo {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  margin-left: auto;
+}
+.ze-pcm-addrepo input {
+  width: 200px;
+}
+.ze-pcm-error {
+  padding: 6px 12px;
+  color: #ff9a9a;
+  background: rgba(180, 40, 40, 0.15);
+  font-size: 12px;
+}
+
+.ze-pcm-tabs {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 2px;
+  padding: 6px 12px 0;
+  border-bottom: 1px solid var(--chrome-border);
+}
+.ze-pcm-tab {
+  padding: 6px 14px;
+  background: transparent;
+  border: 1px solid transparent;
+  border-bottom: none;
+  border-radius: 4px 4px 0 0;
+  color: #9a9ca0;
+  cursor: pointer;
+  font: inherit;
+}
+.ze-pcm-tab:hover {
+  color: var(--chrome-fg);
+}
+.ze-pcm-tab.active {
+  color: var(--chrome-fg);
+  background: var(--chrome-bg2);
+  border-color: var(--chrome-border);
+}
+
+.ze-pcm-body {
+  display: block;
+  overflow: auto;
+  padding: 10px 12px;
+}
+.ze-pcm-empty {
+  padding: 24px;
+  text-align: center;
+  line-height: 1.6;
+}
+
+.ze-pcm-list {
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+}
+.ze-pcm-card {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 10px 12px;
+  background: var(--chrome-bg2);
+  border: 1px solid var(--chrome-border);
+  border-radius: 6px;
+}
+.ze-pcm-card-main {
+  flex: 1;
+  min-width: 0;
+}
+.ze-pcm-card-title {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  flex-wrap: wrap;
+}
+.ze-pcm-card-title .name {
+  font-weight: 600;
+}
+.ze-pcm-card-title .ver {
+  font-size: 11px;
+  color: #9a9ca0;
+}
+.ze-pcm-card-desc {
+  margin-top: 3px;
+  font-size: 13px;
+  color: #d7d8da;
+}
+.ze-pcm-card-meta {
+  margin-top: 3px;
+  font-size: 11px;
+  color: #9a9ca0;
+}
+.ze-pcm-card-actions {
